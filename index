<title>Black Echo Grill - Montpellier</title>

<style>
body{
margin:0;
font-family:Arial, sans-serif;
background:#0b0b0b;
color:white;
scroll-behavior:smooth;
}

/* NAV */
nav{
position:fixed;
top:0;
width:100%;
background:#111;
display:flex;
justify-content:center;
padding:15px;
z-index:1000;
border-bottom:1px solid #222;
}

nav a{
color:white;
margin:0 18px;
text-decoration:none;
font-weight:bold;
transition:0.3s;
}

nav a:hover{
color:#ff3b3b;
}

/* HEADER */
header{
height:100vh;
background:
linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.8)),
url('https://images.unsplash.com/photo-1511379938547-c1f69419868d');
background-size:cover;
background-position:center;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
}

header h1{
font-size:70px;
margin:0;
letter-spacing:5px;
}

header p{
color:#ff3b3b;
font-size:18px;
}

/* SECTIONS */
section{
padding:100px 20px;
max-width:1000px;
margin:auto;
}

h2{
color:#ff3b3b;
border-left:4px solid #ff3b3b;
padding-left:10px;
}

/* CARDS */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.card{
background:#161616;
padding:20px;
border-radius:10px;
border:1px solid #222;
}

/* EVENTS */
.event{
background:#111;
padding:20px;
margin-bottom:15px;
border-left:4px solid #ff3b3b;
}

/* FOOTER */
footer{
text-align:center;
padding:40px;
background:#000;
border-top:1px solid #222;
}

.small{
color:#aaa;
font-size:13px;
}
</style>
</head>

